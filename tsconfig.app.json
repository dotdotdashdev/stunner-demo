{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2023",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client", "@webgpu/types"],
    "skipLibCheck": true,
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "paths": {
      "@dotdotdash/stunner-core": [
        "../stunner/packages/stunner-core/src/index.ts",
        "node_modules/@dotdotdash/stunner-core/src/index.ts"
      ],
      "@dotdotdash/stunner-core/*": [
        "../stunner/packages/stunner-core/src/*",
        "node_modules/@dotdotdash/stunner-core/src/*"
      ],
      "@dotdotdash/stunner-react": [
        "../stunner/packages/stunner-react/src/index.ts",
        "node_modules/@dotdotdash/stunner-react/src/index.ts"
      ],
      "@dotdotdash/stunner-draco": [
        "../stunner/packages/stunner-draco/src/index.ts",
        "node_modules/@dotdotdash/stunner-draco/src/index.ts"
      ],
      "@dotdotdash/stunner-usd": [
        "../stunner/packages/stunner-usd/src/index.ts",
        "node_modules/@dotdotdash/stunner-usd/src/index.ts"
      ],
      "@dotdotdash/stunner-usd/*": [
        "../stunner/packages/stunner-usd/src/*",
        "node_modules/@dotdotdash/stunner-usd/src/*"
      ],
      "@dotdotdash/stunner-core/*": [
        "../stunner/packages/stunner-core/src/*",
        "node_modules/@dotdotdash/stunner-core/src/*"
      ]
    },

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["src"]
}
